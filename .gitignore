# Bundled Python dependencies.
# NVDA ships Python 3.11 32-bit, so C extensions must match that ABI.
# Install locally via:
#   uv pip install --python 3.11 --target addon/lib64 --python-platform x86_64-pc-windows-msvc -r addon/requirements.txt
#   uv pip install --python 3.11 --target addon/lib32 --python-platform i686-pc-windows-msvc   -r addon/requirements.txt
# They are intentionally NOT committed because they are large and
# platform-specific.
/addon/lib32/
/addon/lib64/
