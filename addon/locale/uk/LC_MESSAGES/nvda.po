#: addon\globalPlugins\GemVDA\__init__.py:276
#: addon\globalPlugins\GemVDA\__init__.py:1001
msgid ""
"Summarize the following text concisely. Respond in the same language as the "
"text:"
msgstr ""
"Коротко перекажи зміст наведеного нижче тексту. Відповідай тією ж мовою, що "
"й текст:"

